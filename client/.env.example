# Backend API origin — only needed when frontend is deployed separately from the backend.
# Leave blank (or omit) when Express serves both on the same domain.
# Example: https://fieldcore-production-ee0d.up.railway.app
VITE_API_URL=

# Stripe publishable key (safe to expose in client — starts with pk_live_ or pk_test_)
VITE_STRIPE_PUBLISHABLE_KEY=
