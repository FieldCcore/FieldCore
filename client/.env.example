# Backend API origin — only needed when frontend is deployed separately from the backend.
# Leave blank (or omit) when Express serves both on the same domain.
# Example: https://fieldcore-production-ee0d.up.railway.app
VITE_API_URL=

# Stripe publishable key (safe to expose in client — starts with pk_live_ or pk_test_)
VITE_STRIPE_PUBLISHABLE_KEY=

# Google Maps JavaScript API key — baked in at Vite build time.
# Required for the map to render. Set in Vercel env vars for production.
# For local dev: copy this to client/.env.local and fill in your key.
# Same underlying key as GOOGLE_MAPS_API_KEY (backend). Restrict to HTTP referrers in GCP Console.
VITE_GOOGLE_MAPS_API_KEY=

# Optional: Cloud Map ID for AdvancedMarker support (removes dev watermark).
VITE_GOOGLE_MAPS_MAP_ID=
