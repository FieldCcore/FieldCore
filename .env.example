# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/fieldcore

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-string-minimum-32-chars

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
# Public-facing app URL. Also controls the CORS allowed-origin list — the www variant
# is derived automatically (e.g. APP_URL=https://getfieldcore.com also allows https://www.getfieldcore.com).
APP_URL=https://your-app-url.com

# ── Web Dashboard ─────────────────────────────────────────────────────────────
# Backend origin used by the React/Vite web dashboard. Set in client/.env.
VITE_API_URL=https://your-api-url.com

# ── Mobile App (EAS Build) ────────────────────────────────────────────────────
# Backend origin baked into the Expo binary at build time. Must be set before
# running `eas build` — cannot be changed after the binary is distributed.
EXPO_PUBLIC_API_URL=https://your-api-url.com

# ── Security ──────────────────────────────────────────────────────────────────
# Comma-separated list of admin email addresses.
# Used for: cancellation notifications, admin metrics gate, security alerts.
# First address in the list receives notification emails.
# All addresses in the list can access /api/billing/admin-metrics.
ADMIN_EMAILS=admin@getfieldcore.com,kevincaines925@gmail.com

# Email for low-level security alerts (brute force, API errors, etc.) — used by audit.js
ADMIN_ALERT_EMAIL=admin@getfieldcore.com

# ── Stripe Platform ───────────────────────────────────────────────────────────
# Get from: dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...

# Get from: dashboard.stripe.com/webhooks → your endpoint → Signing secret
# For local dev: stripe listen --forward-to localhost:3000/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_...

# Get from: dashboard.stripe.com/products → each plan's Price ID (price_...)
# Create one product per plan in Stripe; copy the monthly Price ID for each.
STRIPE_PRICE_SOLO=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_SCALE=price_...

# Platform fee charged per transaction (default 1%)
PLATFORM_FEE_PERCENT=1

# ── Messaging Provider Switch ─────────────────────────────────────────────────
# Controls where outbound client messages (SMS/iMessage/RCS) are routed.
#
# PHASE 1 — Twilio SMS (current, active after A2P 10DLC approval):
#   MESSAGING_PROVIDER=twilio   (or leave unset — twilio is the default)
#   SMS_ENABLED=true            (flip this once Delaware C-Corp A2P is approved)
#
# PHASE 2 — Sendblue iMessage/RCS/SMS (after app store approval + $100/mo plan):
#   MESSAGING_PROVIDER=sendblue
#   SENDBLUE_API_KEY_ID=sb-api-key-...
#   SENDBLUE_API_SECRET_KEY=sb-api-secret-...
#
# Twilio stays for voice regardless of which provider is set.
MESSAGING_PROVIDER=twilio

# ── Twilio (Voice + SMS fallback) ─────────────────────────────────────────────
# Get from: console.twilio.com
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...
# Flip to true once A2P 10DLC registration is approved by carriers
SMS_ENABLED=false

# ── Sendblue (iMessage / RCS / SMS — activate after app store approval) ────────
# $100/month per phone line. Free sandbox is inbound-only (cannot send to clients).
# Sign up at: sendblue.com — get keys from dashboard → API Keys
# After signing up, set webhook URL in Sendblue dashboard to:
#   ${APP_URL}/api/webhooks/sendblue  (replace with your production APP_URL)
SENDBLUE_API_KEY_ID=sb-api-key-...
SENDBLUE_API_SECRET_KEY=sb-api-secret-...

# ── SMTP (email) ──────────────────────────────────────────────────────────────
# Omit to log emails to console in dev (no real emails sent)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your-app-password   # Gmail: use an App Password, not your login password
FROM_EMAIL=noreply@getfieldcore.com

# ── Google Maps ───────────────────────────────────────────────────────────────
# Same key used on web and mobile
VITE_GOOGLE_MAPS_API_KEY=AIzaSy...

# ── AI Chat Widget ────────────────────────────────────────────────────────────
# Get from: console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ── File Storage (Cloudflare R2 or AWS S3) ───────────────────────────────────
# Cloudflare R2 (recommended — no egress fees):
#   Endpoint format: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
#   Create R2 bucket in Cloudflare dashboard → R2 → Create bucket
#   Create API token: R2 → Manage R2 API Tokens → Create Token (Object Read & Write)
#   Enable public access on bucket → copy the public URL
# AWS S3: omit R2_ENDPOINT, set R2_REGION to your bucket region (e.g. us-east-1)
R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=...
R2_SECRET_ACCESS_KEY=...
R2_BUCKET=fieldcore-uploads
R2_PUBLIC_URL=https://your-bucket-public-url.com
R2_REGION=auto

# ── Beta Signup ───────────────────────────────────────────────────────────────
BETA_CAP=100
CONTACT_EMAIL=info@getfieldcore.com

# ── Seed (npm run db:init) ────────────────────────────────────────────────────
SEED_EMAIL=admin@yourdomain.com
SEED_PASSWORD=change-me
