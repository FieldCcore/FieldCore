# Database
DATABASE_URL=postgresql://user:password@host:5432/fieldcore

# Auth
JWT_SECRET=change-this-to-a-long-random-string

# App
NODE_ENV=production
PORT=3000

# Stripe (add when ready)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Twilio (add when ready)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_FROM_NUMBER=+1...

# SMTP (for password reset emails — omit to log reset links to console in dev)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your-app-password
FROM_EMAIL=noreply@fieldcore.app
APP_URL=https://your-app-url.com

# Seed (used by npm run db:init)
SEED_EMAIL=admin@yourdomain.com
SEED_PASSWORD=change-me
